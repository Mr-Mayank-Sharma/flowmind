{
  "name": "@flowmind/cli",
  "version": "0.1.0",
  "private": true,
  "description": "FlowMind CLI — Terminal AI Agent Framework (like OpenCode)",
  "type": "module",
  "bin": {
    "flowmind": "./dist/index.js"
  },
  "scripts": {
